# WHITELIST repo: ignore everything by default, then allow ONLY our own original
# files. This guarantees no secrets (djtt/ cookies) and no third-party mappings
# (decode/, *.bin, Reybans*, ref*, TraktorCommands.swift, etc.) are ever committed.
/*

# our own work:
!/.gitignore
!/.gitattributes
!/LICENSE
!/SECURITY.md
!/README.md
!/HANDOFF.md
!/README_gideonSTEMsMaster.md
!/MASCHINE_MK2_PROJECT_REFERENCE.md
!/TRAKTOR_MAPPING_NOTES.md
!/build_gideonStemsMaster.py
!/make_layout.py
!/make_public_catalog.py
!/annotate_template.py
!/gideonSTEMsMaster.tsi
!/gideonSTEMsMaster.ncc
!/master.png
!/cheatsheet.png
!/listing_image.png
!/template_labeled.png
!/padA.png
!/padB.png
!/padC.png
!/padD.png
!/padE.png
!/padF.png
!/padG.png
!/padH.png
!/images/
!/release_GideonSTEM-Maschine/

